{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ebook Neo",
  "version": "1.0.2",
  "identifier": "work.kyanet.ebookneo",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Ebook Neo",
        "width": 1180,
        "height": 760,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self'; script-src 'self'; connect-src ipc: http://ipc.localhost",
      "devCsp": "default-src 'self'; img-src 'self' data: http://localhost:1420; style-src 'self' 'unsafe-inline' http://localhost:1420; script-src 'self' 'unsafe-eval' http://localhost:1420; connect-src ipc: http://ipc.localhost http://localhost:1420 ws://localhost:1420"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Kyanetwork",
    "windows": {
      "nsis": {
        "template": "windows/nsis/installer.nsi",
        "languages": ["SimpChinese", "English"]
      },
      "wix": {
        "language": ["zh-CN", "en-US"]
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
